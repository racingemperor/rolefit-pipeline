{
  "metadata": {
    "version": "0.1.0",
    "language": "zh-CN",
    "scenario": "engineering_campus_recruitment",
    "created_on": "2026-06-26",
    "purpose": "Reusable resume format, section logic, gate rules, HR trust scoring, and version selection for Codex career pipeline.",
    "evidence_policy": "no_fabrication_user_verified_only",
    "default_when_no_target_company": "campus_general_cn_one_page"
  },
  "gate_statuses": {
    "pass": "Format and evidence density are sufficient for ResumeArchitect to draft.",
    "revise_required": "Missing or weak information must be improved before drafting.",
    "user_confirmation_required": "Potentially usable claims require user confirmation before drafting."
  },
  "required_sections": [
    {
      "section_id": "school_info",
      "title": "学校信息",
      "required": true,
      "fields": [
        "school_name",
        "college_or_department",
        "major_name",
        "degree_level",
        "graduation_window",
        "education_type",
        "gpa_or_rank",
        "core_courses",
        "honors_awards",
        "major_cluster_id",
        "cross_tags",
        "target_role_relevance_notes"
      ],
      "minimum_viable_fields": [
        "school_name",
        "major_name",
        "degree_level",
        "graduation_window"
      ],
      "writing_rules": [
        "学历从最高学历写到本科。",
        "GPA/排名只在有优势或岗位要求时展示。",
        "课程只保留与目标岗位相关的 3-6 门。",
        "专业名称应关联 major_cluster_id 和 cross_tags。",
        "校招/实习应明确在读状态、毕业时间和可实习周期。"
      ],
      "trust_logic": [
        "学校、专业、学历和时间线越清楚，HR 越容易判断投递资格。",
        "课程必须服务岗位相关性，不用堆所有课程。"
      ],
      "reject_conditions": [
        "缺学校、专业或学历层级。",
        "毕业时间与求职身份冲突。",
        "疑似伪造或无法确认学历。",
        "海外、转专业或实验班背景没有说明当前身份。"
      ],
      "example_shape": {
        "major_name": "<专业名称>",
        "graduation_window": "<YYYY.MM-YYYY.MM>",
        "core_courses": [
          "<与岗位相关课程>"
        ],
        "target_role_relevance_notes": "<该专业/课程如何支持目标方向>"
      }
    },
    {
      "section_id": "contact",
      "title": "个人联系方式",
      "required": true,
      "fields": [
        "name",
        "phone",
        "email",
        "city_preference",
        "job_intention",
        "portfolio_links",
        "github_or_gitee",
        "personal_website",
        "linkedin_or_maimai_optional"
      ],
      "minimum_viable_fields": [
        "name",
        "email_or_phone",
        "job_intention"
      ],
      "writing_rules": [
        "邮箱或手机号至少一个必须可用。",
        "文件名建议：姓名_学校_专业_学历_申请岗位。",
        "技术岗优先放 GitHub/Gitee、项目文档、demo 或个人网站。",
        "不放身份证号、详细住址、家庭信息。"
      ],
      "trust_logic": [
        "联系方式稳定、岗位意向清楚、作品链接可访问，会降低 HR 沟通成本。",
        "技术岗位的外部链接应能支持项目真实性。"
      ],
      "reject_conditions": [
        "无任何可联系渠道。",
        "联系方式明显错误。",
        "包含身份证、家庭住址、私人敏感信息。",
        "英文简历缺邮箱或地区信息。"
      ],
      "example_shape": {
        "name": "<姓名>",
        "email": "<邮箱>",
        "phone": "<手机号，可选>",
        "job_intention": "<岗位族或目标岗位>",
        "github_or_gitee": "<技术岗优先>"
      }
    },
    {
      "section_id": "skills",
      "title": "掌握技能",
      "required": true,
      "fields": [
        "programming_languages",
        "engineering_tools",
        "frameworks_or_platforms",
        "domain_knowledge",
        "lab_or_test_equipment",
        "data_ai_methods",
        "certificates",
        "skill_evidence_refs",
        "proficiency_level"
      ],
      "minimum_viable_fields": [
        "grouped_skill_items",
        "skill_evidence_refs"
      ],
      "writing_rules": [
        "按岗位族分组，不做关键词堆砌。",
        "每个核心技能最好关联项目、竞赛、实习或课程证据。",
        "熟悉、掌握、精通必须有不同证据门槛。",
        "技能区只做索引，真正能力证明放在项目、实习、竞赛里。"
      ],
      "proficiency_gate": {
        "familiar": "学过或在小任务中使用过，能解释基本概念。",
        "proficient": "在项目中独立使用过，能解释实现、问题和取舍。",
        "expert": "有复杂项目、生产/竞赛/论文级证据，能解释边界和优化。"
      },
      "trust_logic": [
        "技能和项目证据能互相引用时可信度最高。",
        "少写形容词，多给工具、方法、场景和证据。"
      ],
      "reject_conditions": [
        "只有熟练/精通但无项目支撑。",
        "技能与目标岗完全不相关。",
        "技术栈堆砌超过可解释范围。",
        "把正在学习的技能写成已掌握。"
      ],
      "example_shape": {
        "programming_languages": [
          "<语言>"
        ],
        "engineering_tools": [
          "<工具/仪器/软件>"
        ],
        "skill_evidence_refs": [
          "project:<项目ID>",
          "competition:<竞赛ID>"
        ]
      }
    },
    {
      "section_id": "projects_competitions",
      "title": "项目竞赛经历",
      "required": true,
      "fields": [
        "name",
        "type",
        "time_range",
        "role",
        "team_size",
        "background",
        "task",
        "technical_stack",
        "actions",
        "result_metrics",
        "engineering_depth",
        "evidence_links",
        "interview_drill_points"
      ],
      "minimum_viable_fields": [
        "name",
        "role",
        "actions",
        "result_or_evidence"
      ],
      "writing_rules": [
        "每段经历按背景-任务-行动-结果-证据结构化。",
        "优先写本人贡献，而不是团队整体宣传。",
        "结果可量化则量化；不能量化则写交付物、验证方式、复盘结论。",
        "竞赛要写级别、排名/奖项、参赛规模；无名次则写技术产出。",
        "同一项目可为不同岗位生成不同表述重点，但事实不能变。"
      ],
      "bullet_template": "<在什么场景下>，使用<方法/工具>完成<本人动作>，产出<交付物>，通过<指标/测试/评审>验证。",
      "trust_logic": [
        "本人角色、技术动作、结果验证和链接证据越清楚，越容易通过 HR 和技术面深挖。",
        "失败处理、调试过程和取舍能提高工程可信度。"
      ],
      "reject_conditions": [
        "没有任何项目、竞赛或实践。",
        "只有名称没有职责。",
        "把团队成果写成个人主导。",
        "排名、奖项、指标无来源。",
        "涉及 NDA 或内部数据。"
      ],
      "example_shape": {
        "name": "<项目/竞赛名>",
        "role": "<本人角色>",
        "actions": [
          "<本人动作>"
        ],
        "result_metrics": [
          "<指标或交付物>"
        ],
        "evidence_links": [
          "<GitHub/demo/报告/证书>"
        ]
      }
    },
    {
      "section_id": "personality_potential",
      "title": "个人性格和潜力",
      "required": true,
      "fields": [
        "evidence_backed_traits",
        "learning_ability",
        "ownership",
        "collaboration",
        "problem_solving",
        "resilience",
        "growth_signals",
        "risk_notes"
      ],
      "minimum_viable_fields": [
        "evidence_backed_traits"
      ],
      "writing_rules": [
        "不写空泛自评，必须绑定经历证据。",
        "用行为证明性格：主动推进、复盘迭代、跨专业协作、长期投入。",
        "校招可以强调潜力，但不能把未完成学习包装成已掌握成果。",
        "通常不单独写成大段自我评价，而是嵌入项目、总结或附加信息。"
      ],
      "trust_logic": [
        "潜力要由学习曲线、复盘能力、协作方式和长期投入证明。",
        "性格表达必须服务岗位需求，而不是泛泛说认真负责。"
      ],
      "reject_conditions": [
        "全是空泛自评。",
        "与岗位方向不匹配。",
        "出现无法证明的人设，如极强领导力但无经历。",
        "性格描述削弱专业可信度。"
      ],
      "example_shape": {
        "evidence_backed_traits": [
          {
            "trait": "学习能力",
            "evidence_ref": "project:<项目ID>",
            "description": "<通过补齐某项技术并交付项目体现>"
          }
        ]
      }
    }
  ],
  "optional_sections": [
    {
      "section_id": "internship_experience",
      "title": "实习经历",
      "use_when": [
        "有真实实习或企业项目"
      ],
      "reject_if": [
        "只有公司名无职责",
        "违反 NDA"
      ]
    },
    {
      "section_id": "research_publications",
      "title": "科研/论文",
      "use_when": [
        "算法/科研/研究型岗位",
        "保研/科研助理方向"
      ],
      "reject_if": [
        "论文未投稿却写已发表",
        "无法说明方法和贡献"
      ]
    },
    {
      "section_id": "awards_certificates",
      "title": "奖项证书",
      "use_when": [
        "奖项与岗位相关或能证明能力"
      ],
      "reject_if": [
        "低相关奖项过多",
        "证书无法验证"
      ]
    },
    {
      "section_id": "external_assets",
      "title": "外部展示资产",
      "use_when": [
        "技术、设计、产品、科研岗位需要作品证明"
      ],
      "reject_if": [
        "链接不可访问",
        "项目不可解释",
        "暴露隐私或内部材料"
      ]
    },
    {
      "section_id": "interview_drill_points",
      "title": "面试深挖点",
      "use_when": [
        "面试准备",
        "项目附录",
        "技术复盘"
      ],
      "reject_if": [
        "问题无法由用户经历支撑",
        "包含未验证或虚构细节"
      ]
    },
    {
      "section_id": "evidence_links",
      "title": "证据链接",
      "use_when": [
        "需要展示 GitHub、demo、报告、论文、证书或作品集"
      ],
      "reject_if": [
        "链接不可访问",
        "链接暴露隐私或内部资料",
        "链接内容与简历 claim 不一致"
      ]
    }
  ],
  "role_family_overlays": [
