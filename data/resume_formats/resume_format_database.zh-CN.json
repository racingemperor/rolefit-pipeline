  "default_general_profile": {
    "version_id": "campus_general_cn_one_page",
    "target": "校招通用版",
    "use_when": "用户没有明确目标公司或具体 JD。",
    "coverage_strategy": [
      "按专业映射 primary_cluster 和 cross_tags。",
      "保留 2-3 个最能证明工程能力的项目。",
      "技能分为通用工程底座、岗位方向技能、工具链、可迁移能力。",
      "不绑定单一公司话术，覆盖互联网、硬件、新能源、AI 的共同筛选点。"
    ],
    "default_section_order": [
      "contact",
      "school_info",
      "skills",
      "projects_competitions",
      "internship_experience",
      "research_publications",
      "personality_potential"
    ],
    "keyword_strategy": [
      "不要太散，围绕工程底座 + 方向证据。",
      "软件/AI 写编程、数据结构、系统、模型评估、部署。",
      "硬件/嵌入式写电路、C/C++、调试、测试仪器、可靠性。",
      "新能源写材料/电池/工艺/仿真/质量/安全。",
      "机器人/自动化写控制、传感器、ROS/仿真、实机联调。"
    ]
  },
