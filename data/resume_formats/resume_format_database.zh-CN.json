  "hr_trust_score_rubric": {
    "total": 100,
    "pass_threshold": 75,
    "revise_threshold": 60,
    "dimensions": [
      {
        "id": "information_completeness",
        "name": "信息完整度",
        "weight": 20,
        "scoring": "五板块是否齐全，目标岗位是否明确。"
      },
      {
        "id": "evidence_strength",
        "name": "证据强度",
        "weight": 25,
        "scoring": "项目、竞赛、实习、论文、作品链接是否支撑 claim。"
      },
      {
        "id": "role_relevance",
        "name": "岗位相关度",
        "weight": 20,
        "scoring": "技能和项目是否匹配 JD must-have / hidden requirements。"
      },
      {
        "id": "readability_format_stability",
        "name": "可读性与格式稳定性",
        "weight": 10,
        "scoring": "结构是否清楚，是否适合 ATS 和人工快速浏览。"
      },
      {
        "id": "truthfulness_risk",
        "name": "真实性风险",
        "weight": 15,
        "scoring": "夸大、虚构、责任边界、数字来源、NDA 风险越低分越高。"
      },
      {
        "id": "growth_potential_expression",
        "name": "成长潜力表达",
        "weight": 10,
        "scoring": "学习曲线、复盘能力、协作方式是否由经历证明。"
      }
    ],
    "decision": [
      ">=75: pass if no hard reject condition.",
      "60-74: user_confirmation_required or revise_required depending on missing evidence.",
      "<60: revise_required; output missing material checklist only."
    ]
  },
  "validation_rules": [
    {
      "rule_id": "base.required_sections.v1",
      "severity": "hard",
      "description": "基础五板块必须可解析或可映射。"
    },
    {
      "rule_id": "base.contact.viable.v1",
      "severity": "hard",
      "description": "邮箱或电话至少一个可用；禁止身份证、详细住址、家庭信息。"
    },
    {
      "rule_id": "base.school.identity.v1",
      "severity": "hard",
      "description": "学校、专业、学历/年级或毕业时间必须清楚。"
    },
    {
      "rule_id": "base.skills.evidence.v1",
      "severity": "medium",
      "description": "核心技能需要项目、竞赛、实习或课程证据引用。"
    },
    {
      "rule_id": "base.project.action_result.v1",
      "severity": "hard",
      "description": "至少一个项目/竞赛经历必须包含本人动作和结果或证据。"
    },
    {
      "rule_id": "base.potential.evidence.v1",
      "severity": "medium",
      "description": "性格和潜力必须由经历证据支撑，不能只写空泛自评。"
    },
    {
      "rule_id": "truth.no_fabrication.v1",
      "severity": "hard",
      "description": "禁止编造学历、实习、奖项、论文、专利、项目数据。"
    },
    {
      "rule_id": "truth.no_overclaim.v1",
      "severity": "hard",
      "description": "禁止把参与写成主导、把未完成写成上线/量产/发表。"
    },
    {
      "rule_id": "format.ats_readable.v1",
      "severity": "medium",
      "description": "招聘系统版本应避免图片化、复杂表格和文本框。"
    }
  ],
  "ban_or_downrank": {
    "forbidden": [
      "编造学历、实习、奖项、论文、专利、项目数据。",
      "身份证号、详细住址、家庭背景、未授权隐私信息。",
      "未完成项目写成已上线、已量产、已发表。",
      "使用无法证明的绝对表述：精通全部技术、独立负责整个系统等。"
    ],
    "downrank": [
      "空泛自评：认真负责、吃苦耐劳、抗压强。",
      "与岗位无关的课程、社团、兴趣爱好。",
      "没有证据支撑的技能列表。",
      "低相关、低级别、无结果的奖项。",
      "过度花哨排版、图片化简历、复杂表格文本框。"
    ]
  },
